// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
  "name": "QDMI Backend Development",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteEnv": {
    "QAPTIVA_AUXILIARY_SCRIPT_LOCATION": "/workspaces/QDMI-Devices/src/simulators/eviden",
    "QAPTIVA_AUXILIARY_SCRIPT_NAME": "qaptiva_auxiliary",

    "QAPTIVA_HOST_URL": "host.docker.internal:20501",
    "QAPTIVA_NOISYHOST_URL": "http://host.docker.internal:20502/run",

    "DCDB_HOST_URL": "host.docker.internal:9042",
    "DCDB_SOURCE_LOCATION": "/workspaces/DCDB/dcdb/",
    "LD_LIBRARY_PATH": "/workspaces/DCDB/install/lib",

    "LRZ_HOST_URL": "https://portal.quantum.lrz.de:4000/v1",

    // TODO: It isn't great to set the values for all developers at once.
    "PARITYQC_SCRIPT_PATH": "/workspaces/MQSS-QDMI-Devices-Suite/src/isv/parityqc/",
    "PARITYQC_PARITYOS_WRAPPER_SCRIPT_NAME": "parityos_wrapper",
    // Local parity api. You have to set it up yourself.
    "PARITYQC_PARITYOS_BASEURL": "http://localhost:8000/v3"
  },

  // TODO: this is needed for accessing local version of parityapi at localhost. For local testing
  // something like this will still be needed. Have to figure this out or discuss if this can even
  // stay here.
  "runArgs": ["--network=host"]
}
