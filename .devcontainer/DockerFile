FROM --platform=x86_64 python:3.11-bookworm

ENV TZ="Europe/Berlin"

RUN apt-get update -y && \
    apt-get autoremove -y
RUN apt-get install -y software-properties-common bash-completion cmake build-essential iputils-ping rsync p7zip-full libuv1-dev git
RUN pip install myqlm-interop[all] flask

WORKDIR /home

CMD ["bash"]
