                       ASSERT_EQ(LRZ_QDMI_device_session_query_device_property(
                                     session, QDMI_DEVICE_PROPERTY_QUBITSNUM,
                                     sizeof(size_t), &num_qubits, nullptr),
                                 QDMI_SUCCESS);)
}
